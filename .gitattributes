# Normalize line endings
* text=auto
*.dart text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.svg text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary
*.apk binary
*.aab binary
